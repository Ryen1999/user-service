<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.userservice.dao.UserInfoDao">
    <insert id="insertUserInfo" parameterType="String">
        insert into user_info(username, password) values (#{username}, #{password})
    </insert>

    <update id="updateUserInfo" parameterType="com.example.userservice.dto.UserInfo">
        update user_info
        <set>
            <if test="roles != null">
                roles = #{roles},
            </if>
            <if test="avatarUrl != null">
                avatar_url = #{avatarUrl},
            </if>
            <if test="createTime != null">
                create_time = #{createTime},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime},
            </if>
            <if test="bonus != null">
                bonus = #{bonus},
            </if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteUserInfo" parameterType="String">
        delete from user_info where username = #{username}
    </delete>

    <select id="queryUserInfoByUserId" parameterType="String"
            resultType="com.example.userservice.dto.UserInfo">
        select * from user_info where id = #{userId, jdbcType=VARCHAR}
    </select>

    <select id="queryUserInfoList" resultType="com.example.user.api.dto.UserInfoResDTO">
    select id, username, password from user_info
</select>


</mapper>